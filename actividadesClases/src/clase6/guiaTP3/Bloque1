package clase6.guiaTP3;

import interfaces.ColaTDA;
import interfaces.ColaPrioTDA;
import implementacionDinamica.colaDinamica.ColaDinamica;
import implementacionDinamica.colaPrioridadDinamica.ColaPrioridadDinamica;

public class Bloque2 {

    public void simularColaComun() {
        ColaTDA impresora = new ColaDinamica();
        impresora.InicializarCola();
        
        impresora.Acolar(101);
        impresora.Acolar(102);
        impresora.Acolar(103);
        
        impresora.Desacolar();
    }

    public void simularColaPrioridad() {
        ColaPrioTDA hospital = new ColaPrioridadDinamica();
        hospital.InicializarCola();
        
        hospital.AcolarPrioridad(10, 1);
        hospital.AcolarPrioridad(25, 100);
        hospital.AcolarPrioridad(40, 50);
        
        hospital.Desacolar();
    }
}